{
  "name": "lineup",
  "version": "0.1.0",
  "private": true,
  "description": "LineUp virtual queue and waitlist SaaS platform.",
  "scripts": {
    "dev": "node scripts/clean-next-cache.mjs && next dev --hostname 0.0.0.0",
    "dev:local": "node scripts/clean-next-cache.mjs && next dev --hostname 127.0.0.1",
    "build": "node scripts/clean-next-cache.mjs && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.86.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.6",
    "openai": "^6.9.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "stripe": "^18.5.0",
    "tailwind-merge": "^2.6.0",
    "twilio": "^5.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.6",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
