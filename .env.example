# App
# Optional. Leave blank for Vercel demo deployments; Vercel supplies the public host.
NEXT_PUBLIC_APP_URL=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_WAIT_MODEL=gpt-5-mini
OPENAI_INSIGHTS_MODEL=gpt-5-mini

# Twilio SMS
TWILIO_ACCOUNT_SID=
