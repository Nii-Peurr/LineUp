# Email
RESEND_API_KEY=
EMAIL_FROM=LineUp <updates@yourdomain.com>

# Firebase Push
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
